# Test host for Ansible: Ubuntu 24.04 with SSH access.
# We deliberately do NOT run systemd here; sshd is started by the entrypoint
# and nginx is managed by Ansible through the LSB init script (/etc/init.d/nginx)
# that ships with the Debian/Ubuntu nginx package.
FROM ubuntu:24.04

# Avoid interactive prompts during apt installs.
ENV DEBIAN_FRONTEND=noninteractive

# Bootstrap packages:
#  - openssh-server : SSH access for Ansible (required by the task)
#  - python3        : required by Ansible modules on the managed node
#  - sudo           : privilege escalation for the deploy user
#  - ca-certificates: TLS for downloading static later
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        openssh-server \
        python3 \
        sudo \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /run/sshd

# Dedicated bootstrap user that Ansible connects as.
# Passwordless sudo so the playbook can become root; the "real" users are
# managed later by the users role. The ssh hardening role disables root login,
# which is fine because we never connect as root.
ARG DEPLOY_USER=deploy
RUN useradd --create-home --shell /bin/bash "${DEPLOY_USER}" \
    && usermod -aG sudo "${DEPLOY_USER}" \
    && echo "${DEPLOY_USER} ALL=(ALL) NOPASSWD:ALL" > "/etc/sudoers.d/${DEPLOY_USER}" \
    && chmod 0440 "/etc/sudoers.d/${DEPLOY_USER}"

# Install the public key generated by scripts/gen_keys.sh.
# The build context is the repo root (see docker-compose.yml).
COPY keys/id_ansible.pub /tmp/id_ansible.pub
RUN install -d -m 0700 -o "${DEPLOY_USER}" -g "${DEPLOY_USER}" "/home/${DEPLOY_USER}/.ssh" \
    && install -m 0600 -o "${DEPLOY_USER}" -g "${DEPLOY_USER}" \
        /tmp/id_ansible.pub "/home/${DEPLOY_USER}/.ssh/authorized_keys" \
    && rm -f /tmp/id_ansible.pub

COPY docker/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

EXPOSE 22 80

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
